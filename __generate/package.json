{
  "name": "blog-creation-tool",
  "version": "1.0.0",
  "description": "Converts markdown articles to an html blog.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "nodemon --experimental-loader ./loader.mjs --ext js,jsx,md,mdx generate.js",
    "build": "node --experimental-loader ./loader.mjs generate.js",
    "dev": "concurrently \"npm run start\" \"live-server ../\""
  },
  "keywords": [
    "markdown",
    "blog",
    "converter",
    "html"
  ],
  "author": "cdnkr",
  "license": "ISC",
  "homepage": "/",
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/register": "^7.25.9",
    "@tailwindcss/typography": "^0.5.16",
    "concurrently": "^9.1.2",
    "dotenv": "^16.3.1",
    "esbuild": "^0.20.1",
    "live-server": "^1.2.2",
    "marked": "^15.0.7",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.1",
    "@mdx-js/mdx": "^3.0.0",
    "@mdx-js/react": "^3.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}